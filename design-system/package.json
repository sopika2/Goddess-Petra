{
  "name": "@gp/design-system",
  "version": "0.1.0",
  "private": true,
  "description": "Goddess Petra design system — reusable, framework-agnostic React components extracted from the GP site.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": ["dist"],
  "scripts": {
    "build": "node build.mjs && tsc -p tsconfig.json --emitDeclarationOnly && tailwindcss -i ./src/styles.css -o ./dist/styles.css --minify",
    "build:js": "node build.mjs",
    "build:types": "tsc -p tsconfig.json --emitDeclarationOnly",
    "build:css": "tailwindcss -i ./src/styles.css -o ./dist/styles.css --minify"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "esbuild": "^0.24.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.0"
  }
}
