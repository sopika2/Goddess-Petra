# Copy this file to .env.local and change the values.

# Password for the /admin area (fallback login). CHANGE THIS to something only you know.
ADMIN_PASSWORD=change-me-now

# REQUIRED. A long (>=24 char) random secret that signs the admin session.
# Login FAILS CLOSED if this is missing, too short, or a placeholder.
# Generate one, e.g. in a terminal:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SESSION_SECRET=replace-with-a-long-random-string

# Public name shown around the site. Optional.
NEXT_PUBLIC_SITE_NAME=Goddess Petra

# Public X/Twitter handle for the "Follow on X" link (without the @). Optional.
NEXT_PUBLIC_TWITTER_HANDLE=Goddess_Petrax3

# Public URL of the live site (your domain / Cloudflare-tunnel hostname).
# Used for canonical links, Open Graph images, robots.txt and sitemap.xml.
NEXT_PUBLIC_SITE_URL=https://your-domain.example

# ---- "Sign in with X" (recommended) ----------------------------------------
# Create an app at https://developer.x.com with OAuth 2.0 enabled (see README).
# When configured, the login page shows "Sign in with X" and ONLY the account
# below may enter the admin area.
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
# Must EXACTLY match a Callback URL registered in your X app (scheme/host/port/path).
TWITTER_CALLBACK_URL=http://localhost:3000/api/auth/twitter/callback
# Only this X account may sign in as admin (username without @).
ADMIN_TWITTER_USERNAME=Goddess_Petrax3
# After your first X login, the server console logs your numeric id. Paste it
# here to pin admin to the immutable id (safer — usernames can change).
ADMIN_TWITTER_ID=

# ---- Database (MariaDB / MySQL) ----
# The app auto-creates the database + tables on startup (no manual SQL needed),
# as long as the user has rights to CREATE DATABASE (or the DB already exists).
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=gp

# ---- Hosting ----
# Set to 1 ONLY when behind a Cloudflare tunnel or a trusted reverse proxy:
# the real client IP is then read from CF-Connecting-IP. Leave 0 (or unset) for
# bare/self-hosted runs, where the IP is taken from the actual socket.
# This also turns on the Secure flag for auth cookies (the connection is HTTPS),
# so the admin session token never crosses a plaintext hop.
# When 1, the visitor log also records country/city/region from Cloudflare's
# location headers — enable them in Cloudflare: Rules → Transform Rules →
# Managed Transforms → "Add visitor location headers".
TRUST_PROXY_HEADERS=0

# Force the Secure flag on auth cookies on/off (1/0). Leave unset to follow
# TRUST_PROXY_HEADERS. Set 0 only if you must reach the admin over plain http.
# COOKIE_SECURE=
